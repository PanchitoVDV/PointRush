[Unit]
Description=PointRush Stats Website
After=network.target mongod.service
Wants=mongod.service

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/pointrush/web
EnvironmentFile=/opt/pointrush/web/.env
ExecStart=/usr/bin/node server/index.js
Restart=on-failure
RestartSec=5

# Alleen lokaal bereikbaar; Caddy/Nginx doet HTTPS naar buiten
Environment=HOST=127.0.0.1

[Install]
WantedBy=multi-user.target
